{
  "expo": {

    "scheme": "acme",
    "web": {
      "bundler": "metro"
    },
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FFCB69",
          "sounds": ["./assets/sounds/notification.wav"]
        }
      ]
    ],
    "android": {
      "adaptativeIcon": "./assets/images/adaptative-icon.png",
      "backgroundColor": "#FFFFFF",
      "package": "com.devlucasdeangelo.adoracaoapp",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "useNextNotificationsApi": true
    },
    "extra": {
      "eas": {
        "projectId": "7fb8612e-d933-4295-ade4-8de08a6be8be"
      }
    },
    "ios": {
      "bundleIdentifier": "com.devlucasdeangelo.adoracaoapp",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    }
  }
}
